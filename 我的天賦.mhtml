ox-shadow: rgba(0, 0, 0, 0.1) 0px 1px 1px; background-color: rgb(248, 248, =
248); border: 1px solid rgb(198, 198, 198); color: rgb(51, 51, 51); }

.modal-dialog-buttons button:active { box-shadow: rgba(0, 0, 0, 0.1) 0px 1p=
